@CatCareApi_HostAddress = http://localhost:5100

POST {{CatCareApi_HostAddress}}/api/breeds
Content-Type: application/json

{
  "name": "Domestic Shorthair",
  "description": "Friendly mixed-breed short-haired cat."
}

###

POST {{CatCareApi_HostAddress}}/api/owners
Content-Type: application/json

{
  "fullName": "Cami Example",
  "email": "cami@example.com",
  "phoneNumber": "+32 123 456 789",
  "address": "Brussels"
}

###

POST {{CatCareApi_HostAddress}}/api/cats
Content-Type: application/json

{
  "name": "Milo",
  "dateOfBirth": "2022-05-14T00:00:00",
  "sex": "Male",
  "color": "Black and white",
  "microchipNumber": "981020000000000",
